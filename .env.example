# PostgreSQL connection string (Neon, Supabase, or any Postgres provider)
# Neon example: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=verify-full
DATABASE_URL=postgresql://user:password@host:5432/suavius?sslmode=verify-full

# Used to sign JWT tokens etc. Generate a strong random string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=replace-me-with-a-long-random-string

# Cloudflare R2 (S3-compatible object storage for product images)
# Create bucket + API token at https://dash.cloudflare.com -> R2 Object Storage
R2_BUCKET=your-bucket-name
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Stripe - get keys from https://dashboard.stripe.com/test/apikeys (test mode)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret: locally from `stripe listen --forward-to localhost:3000/api/webhooks/stripe`,
# production from Dashboard -> Developers -> Webhooks -> your endpoint -> Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Site URL for Stripe success/cancel URLs and webhook callbacks
# Local: http://localhost:3000, prod: https://suaviusatelier.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# SMTP for transactional emails (order confirmations).
# Host/port/credentials come from your mail provider's panel.
SMTP_HOST=smtp.your-mail-host.example
SMTP_PORT=465
SMTP_USER=orders@your-domain.example
SMTP_PASSWORD=
